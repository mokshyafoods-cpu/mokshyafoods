{
  "name": "mokshya-foods-backend",
  "version": "1.0.0",
  "description": "Backend API for Mokshya Foods e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node -e \"const fs=require('fs');const path=require('path');const candidate=path.join(process.cwd(),'dist','server.js');if(fs.existsSync(candidate)){require(candidate)}else{console.error('dist/server.js not found, trying src/server.ts');require('ts-node/register/transpile-only');require('./src/server.ts')}\"",
    "dev": "ts-node --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongodb",
    "nepal"
  ],
  "author": "Mokshya Foods",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^2.2.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
